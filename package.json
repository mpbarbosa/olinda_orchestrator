{
  "name": "olinda-orchestrator",
  "version": "0.5.0",
  "description": "A generic orchestrator TypeScript Library",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:docker": "bash ./scripts/run-tests-docker.sh",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run lint && npm run build"
  },
  "keywords": [
    "orchestrator",
    "typescript"
  ],
  "author": "mpbarbosa",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.9.1",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.1",
    "prettier": "^3.8.3",
    "typescript": "^5.5.3",
    "vitest": "^4.1.5"
  }
}
